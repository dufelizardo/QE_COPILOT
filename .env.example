# QE Copilot — variáveis de ambiente
# Copie para .env e preencha. Nunca commite o .env.

# Provider B3GPT (obrigatório)
B3GPT_TOKEN=sua-api-key-aqui
B3GPT_MODEL_NAME=nome-do-deployment-aqui
B3GPT_BASE_URL=https://api-b3gpt.b3.com.br/internal-api/b3gpt-llms/v1/openai
B3GPT_TIMEOUT=60

# API
API_KEY=                          # vazio = sem autenticação

# RAG
RAG_ENABLED=false                 # true para habilitar RAG
VECTOR_STORE_TYPE=chroma          # chroma | faiss | qdrant
VECTOR_STORE_PATH=./data/vectorstore
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Observabilidade
LOG_LEVEL=INFO
LOG_FORMAT=json

# App
APP_ENV=development
MAX_RETRIES=2
